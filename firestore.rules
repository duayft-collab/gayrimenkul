rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Giriş yapmış kullanıcılar tüm to_ koleksiyonlarına erişebilir
    match /to_{collection}/{document} {
      allow read, write: if request.auth != null;
    }

    // Kullanıcı profilleri — sadece kendi profilini okuyabilir
    // Admin tümünü okuyabilir
    match /to_users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/to_users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/to_users/$(request.auth.uid)).data.role == 'admin');
    }

  }
}
